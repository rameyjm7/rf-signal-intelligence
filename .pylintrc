[MASTER]
ignore-paths=
    ^src/rf_signal_intelligence/base/.*$
    ^src/rf_signal_intelligence/legacy/.*$
    ^src/rf_signal_intelligence/core/base_classifier.py$
    ^src/rf_signal_intelligence/models/rnn_lstm_with_snr.py$

[MESSAGES CONTROL]
disable=
    import-error,
    no-name-in-module,
    import-outside-toplevel,
    duplicate-code,
    too-few-public-methods,
    too-many-instance-attributes,
    missing-module-docstring,
    missing-class-docstring,
    missing-function-docstring,
    invalid-name

[FORMAT]
max-line-length=100
